# Copy to .env and fill in only what you want to activate. Everything is optional.
# With none of these set, the platform runs the full loop keyless using synthetic
# fixtures and a deterministic agent and judge.

# --- LLM (optional) ---
# When set, the agent under test and the LLM judge use Anthropic Claude.
# When unset, a deterministic scripted agent and a rule based judge are used.
ANTHROPIC_API_KEY=
OMBENCH_LLM_PROVIDER=stub        # stub | anthropic
OMBENCH_LLM_MODEL=claude-opus-4-8
OMBENCH_JUDGE_MODEL=claude-opus-4-8

# --- Slack (optional) ---
# When set, the Slack sync adapter ingests a real workspace. When unset, the
# adapter reads synthetic fixtures from fixtures/slack.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Google Workspace (optional) ---
# Path to OAuth client credentials and a stored token for Calendar Drive and Docs
# read only scopes. When unset, the adapters read synthetic fixtures.
GOOGLE_CREDENTIALS_FILE=
GOOGLE_TOKEN_FILE=

# --- Storage (optional overrides) ---
# Root directory for the local store. Defaults to .ombench in the working directory.
OMBENCH_HOME=.ombench
