@startuml layers
' Package layering: each layer depends only on the ones below it.
skinparam backgroundColor white
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam rectangle {
  BackgroundColor #F4F1EA
  BorderColor #555555
}
skinparam ArrowColor #555555

title ombench package layers (dependencies point downward)

rectangle "cli + apps\nomb trace/sync/snapshot/memory/eval/saasgit/viz,\nsync_worker, replay_runner" as cli
rectangle "eval (Tasks 4 + 6)\ntasks, rubrics, judges, runner, stats, reports, miner, seed" as ev
rectangle "replay (Task 5)\nsandbox, sandbox_api, validators, faults" as rp
rectangle "memory (Task 3)\ncompiler, retriever, scorer, resolver, kb, bootstrap" as mem
rectangle "llm\nbase, stub, anthropic_client, agent" as llm
rectangle "integrations (Task 2 sources)\nbase, registry, slack, gcal, gdocs, gmail" as integ
rectangle "snapshots (Task 2)\nmaterialize, manifest, diff" as snap
rectangle "events (history substrate)\nschema/algebra, store, queries" as ev2
rectangle "traces (Task 1)\nschema, ingest, redact, converters, hook, otel_adapter" as tr
rectangle "storage\nStorageBackend, SQLiteBackend, PostgresBackend, BlobStore" as st

cli --> ev
cli --> rp
cli --> mem
cli --> integ
cli --> snap
ev --> rp
ev --> mem
ev --> llm
rp --> llm
rp --> snap
mem --> ev2
llm --> tr
integ --> ev2
snap --> ev2
tr --> st
ev2 --> st

@enduml
